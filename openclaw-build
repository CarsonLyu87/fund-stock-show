#!/bin/bash

# OpenClaw专用构建脚本
# OpenClaw控制UI可以直接调用此脚本进行构建

set -e

echo "🚀 OpenClaw构建脚本启动"
echo "========================"
echo ""

# 获取项目目录
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
echo "📁 项目目录: $PROJECT_DIR"
cd "$PROJECT_DIR"

# 检查环境
echo ""
echo "🔍 环境检查:"
echo "当前目录: $(pwd)"
echo "Node版本: $(node --version 2>/dev/null || echo '未安装')"
echo "npm版本: $(npm --version 2>/dev/null || echo '未安装')"
echo ""

# 检查依赖
if [ ! -d "node_modules" ]; then
    echo "📦 安装依赖..."
    npm install
    echo "✅ 依赖安装完成"
else
    echo "✅ node_modules目录存在"
fi

# 检查vite
if [ ! -f "node_modules/.bin/vite" ]; then
    echo "⚠️  vite未找到，重新安装..."
    npm install vite
    echo "✅ vite安装完成"
else
    echo "✅ vite已安装: node_modules/.bin/vite"
fi

echo ""
echo "🛠️  开始构建..."

# 方法1: 使用npm run build（最可靠）
echo ""
echo "1. 使用 npm run build..."
if npm run build 2>&1; then
    echo ""
    echo "🎉 构建成功！"
    echo ""
    echo "构建文件位于: dist/"
    echo "主要文件:"
    echo "  - dist/index.html"
    echo "  - dist/assets/index-*.js"
    echo "  - dist/assets/index-*.css"
    echo ""
    echo "✅ OpenClaw构建完成"
    exit 0
else
    echo "❌ npm run build 失败，尝试其他方法..."
fi

# 方法2: 使用npx
echo ""
echo "2. 使用 npx vite build..."
if npx vite build 2>&1; then
    echo ""
    echo "🎉 构建成功！"
    echo ""
    echo "✅ OpenClaw构建完成"
    exit 0
else
    echo "❌ npx vite build 失败，尝试其他方法..."
fi

# 方法3: 直接调用vite
echo ""
echo "3. 直接调用 vite build..."
if ./node_modules/.bin/vite build 2>&1; then
    echo ""
    echo "🎉 构建成功！"
    echo ""
    echo "✅ OpenClaw构建完成"
    exit 0
else
    echo "❌ 直接调用vite也失败..."
fi

# 所有方法都失败
echo ""
echo "💥 所有构建方法都失败！"
echo ""
echo "请检查:"
echo "1. 网络连接"
echo "2. 依赖是否完整: npm install"
echo "3. 权限问题"
echo "4. 查看详细错误信息"
echo ""
echo "可以尝试手动构建:"
echo "  cd $PROJECT_DIR"
echo "  npm install"
echo "  npm run build"
echo ""
exit 1