#!/bin/bash

# vite命令的替代实现
# 当系统找不到vite命令时，这个文件可以作为替代

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "⚠️  使用项目本地vite命令包装器"
echo "📁 项目目录: $DIR"

# 检查本地vite
if [ -f "$DIR/node_modules/.bin/vite" ]; then
    echo "✅ 找到本地vite: $DIR/node_modules/.bin/vite"
    exec "$DIR/node_modules/.bin/vite" "$@"
elif [ -f "$DIR/node_modules/vite/bin/vite.js" ]; then
    echo "✅ 找到vite.js: $DIR/node_modules/vite/bin/vite.js"
    exec node "$DIR/node_modules/vite/bin/vite.js" "$@"
else
    echo "❌ 未找到本地vite，尝试使用npx"
    
    # 检查npx是否可用
    if command -v npx &> /dev/null; then
        echo "🚀 使用npx执行: npx vite $@"
        exec npx vite "$@"
    else
        echo "❌ npx不可用，尝试安装依赖"
        
        # 安装依赖
        cd "$DIR" && npm install
        
        if [ -f "$DIR/node_modules/.bin/vite" ]; then
            echo "✅ 安装成功，执行本地vite"
            exec "$DIR/node_modules/.bin/vite" "$@"
        else
            echo "💥 所有方法都失败"
            echo "请手动运行: cd $DIR && npm install"
            exit 1
        fi
    fi
fi