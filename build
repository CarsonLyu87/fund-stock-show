#!/bin/bash

# 构建命令包装器
# 当OpenClaw控制UI调用 "vite build" 时，这个文件可以作为替代

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "=== OpenClaw构建包装器 ==="
echo "📁 项目目录: $DIR"
echo "📦 处理构建命令..."
echo ""

# 检查是否在正确的目录
if [ ! -f "$DIR/package.json" ]; then
    echo "❌ 错误：不在项目目录中"
    echo "请确保在包含package.json的目录中执行"
    exit 1
fi

# 方法1: 使用npm run build（最可靠）
echo "🛠️  方法1: 使用 npm run build..."
cd "$DIR" && npm run build

# 如果npm run build失败，尝试其他方法
if [ $? -ne 0 ]; then
    echo ""
    echo "⚠️  npm run build 失败，尝试其他方法..."
    
    # 方法2: 使用npx
    echo "🛠️  方法2: 使用 npx vite build..."
    cd "$DIR" && npx vite build
    
    if [ $? -ne 0 ]; then
        echo ""
        echo "⚠️  npx vite build 失败，尝试直接调用..."
        
        # 方法3: 直接调用本地vite
        if [ -f "$DIR/node_modules/.bin/vite" ]; then
            echo "🛠️  方法3: 直接调用本地vite..."
            cd "$DIR" && "$DIR/node_modules/.bin/vite" build
        elif [ -f "$DIR/node_modules/vite/bin/vite.js" ]; then
            echo "🛠️  方法3: 使用node运行vite.js..."
            cd "$DIR" && node "$DIR/node_modules/vite/bin/vite.js" build
        else
            echo "❌ 所有构建方法都失败"
            echo "请检查:"
            echo "1. 依赖是否安装: cd $DIR && npm install"
            echo "2. 是否有权限问题"
            echo "3. 查看详细错误日志"
            exit 1
        fi
    fi
fi

echo ""
echo "✅ 构建完成"