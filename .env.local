# 数据服务配置
VITE_API_BASE_URL=http://localhost:3001

# 数据源配置（如果需要API密钥）
# VITE_YAHOO_API_KEY=
# VITE_ALPHA_VANTAGE_API_KEY=
# VITE_TWELVE_DATA_API_KEY=

# 代理配置（如果需要绕过CORS）
VITE_USE_PROXY=false
VITE_PROXY_URL=http://localhost:8080

# 数据更新频率（毫秒）
VITE_UPDATE_INTERVAL=3600000

# 缓存配置
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=1800000