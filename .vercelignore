# 忽略所有JavaScript文件（防止Vercel误认为是函数）
*.js
*.mjs
*.cjs

# 忽略开发服务器文件
proxy-server.js

# 忽略开发依赖
node_modules/

# 忽略构建产物
dist/
build/

# 忽略配置文件
*.local.*
.env
.env.local

# 忽略日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 忽略IDE文件
.vscode/
.idea/
*.swp
*.swo

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略测试文件
__tests__/
__mocks__/
coverage/

# 忽略文档文件
docs/
*.md

# 忽略TypeScript文件
*.ts
*.tsx

# 忽略API目录（如果有）
api/