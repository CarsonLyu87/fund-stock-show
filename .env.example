# 基金股票看板 - 环境变量配置
# 复制此文件为 .env.local 并填写实际的API密钥

# Yahoo Finance API (股票数据)
# 注意：Yahoo Finance免费版不需要API密钥，但有限制
# VITE_YAHOO_API_KEY=your_yahoo_api_key_here

# Alpha Vantage API (备用股票数据源)
# 注册地址：https://www.alphavantage.co/support/#api-key
# VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Twelve Data API (备用股票数据源)
# 注册地址：https://twelvedata.com/apikey
# VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# 东方财富网API配置
# 注意：东方财富网API通常不需要密钥，但有限制
# VITE_EASTMONEY_API_KEY=your_eastmoney_api_key_here

# 天天基金网API配置
# VITE_TIANTIAN_API_KEY=your_tiantian_api_key_here

# 应用配置
VITE_APP_NAME=Fund Stock Show
VITE_APP_VERSION=0.1.0
VITE_API_BASE_URL=https://api.example.com

# 数据更新频率（毫秒）
VITE_STOCK_UPDATE_INTERVAL=30000
VITE_FUND_UPDATE_INTERVAL=60000

# 开发模式配置
VITE_DEV_MODE=true
VITE_USE_MOCK_DATA=true  # 开发时使用模拟数据

# 日志级别
VITE_LOG_LEVEL=info