# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 开发环境
VITE_API_BASE_URL=http://localhost:3001
VITE_PROXY_URL=http://localhost:3001

# 生产环境（部署时设置）
# VITE_API_BASE_URL=https://your-proxy-server.vercel.app
# VITE_PROXY_URL=https://your-proxy-server.vercel.app

# 其他配置
# VITE_APP_TITLE=Fund Stock Show
# VITE_APP_DESCRIPTION=实时基金股票数据展示